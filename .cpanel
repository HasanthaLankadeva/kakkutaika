deployment:
  tasks:
    # Set deployment path for PRODUCTION and DEVELOPMENT
    - |
      if [ "$DEPLOYMENT_BRANCH" = "main" ]; then
        export DEPLOYPATH=/home/kakkutai/public_html
      else
        export DEPLOYPATH=/home/kakkutai/dev.kakkutaika.com
      fi

    # Ensure target directory exists
    - /bin/mkdir -p $DEPLOYPATH

    # Copy all project files to LIVE directory
    - /bin/cp -R . $DEPLOYPATH

    # Remove Git-related files from public directory
    - /bin/rm -rf $DEPLOYPATH/.git
    - /bin/rm -rf $DEPLOYPATH/.gitignore