# Enable rewrite engine
RewriteEngine On

# ----------------------------------------
# 1. Admin folder - leave /admin requests alone
# ----------------------------------------
RewriteRule ^admin(/.*)?$ admin$1 [L]

# ----------------------------------------
# 2. Avoid rewriting requests that already go to /public
# ----------------------------------------
RewriteRule ^public/ - [L]

# ----------------------------------------
# 3. Redirect everything else to public folder
# ----------------------------------------
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/$1 [L]